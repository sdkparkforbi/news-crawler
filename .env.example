# 수집·본문추출만 쓰면 비밀키가 전혀 필요 없습니다.
# 아래 GH_TOKEN 은 private repo 를 Colab에서 클론할 때만 씁니다.
# (Colab Secrets 🔑 에 GH_TOKEN 으로 넣으면 .env 없이도 동작)

# GitHub Personal Access Token (repo read 권한). private repo 클론용.
GH_TOKEN=

# ── 분석 노트북(뉴스분석)용 ──
# bge-m3 임베딩 서버(미들턴). 자체 서버를 쓰면 이 주소만 바꾸세요.
MIDDLETON_URL=https://middleton.p-e.kr/api/embeddings
# bge-m3(①②) 임베딩 키 — 값만 채우세요(주석을 같은 줄에 쓰지 마세요).
MIDDLETON_API_KEY=
# 필터링(gpt-4o-mini)·3large(③④) 임베딩 키
OPENAI_API_KEY=
# 모델명(보통 그대로 두면 됩니다)
BGE_MODEL=bge-m3:latest
OAI_EMB_MODEL=text-embedding-3-large
CLASSIFY_MODEL=gpt-4o-mini

# ── DB 업로드(선택) — 분석 노트북에서 DB업로드=True 일 때만 ──
# 기사·임베딩을 MySQL에 적재합니다. 본인 DB 정보로 채우세요.
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=newsdb
